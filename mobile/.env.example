# Copy to .env and fill in. Values prefixed EXPO_PUBLIC_ are inlined into the app
# at build time. The Supabase publishable (anon) key is safe to ship in a client.
#
# Get these from Supabase -> Settings -> API:
#   EXPO_PUBLIC_SUPABASE_URL       = Project URL (https://<ref>.supabase.co)
#   EXPO_PUBLIC_SUPABASE_ANON_KEY  = the "publishable" key
EXPO_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Backend API. Defaults to the deployed host if unset.
EXPO_PUBLIC_API_URL=https://thotamaali.com
